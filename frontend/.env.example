# Spotify OAuth (developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered in the Spotify dashboard.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# iron-session encryption key (>= 32 characters)
SESSION_PASSWORD=replace_with_at_least_32_random_characters

# Backend URLs
# Browser-facing socket URL (must be reachable from clients).
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:4001
# Server-to-server backend URL used by Next.js API routes.
BACKEND_URL=http://127.0.0.1:4001
# Shared secret for server-to-server calls to backend.
# Must match SOCKET_PROVIDER_SECRET on the backend.
SOCKET_PROVIDER_SECRET=replace_with_a_long_random_string
