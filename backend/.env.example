# Port the socket server listens on
PORT=4001

# Comma-separated list of allowed CORS origins for the socket.io server.
# Include both your dev URL and your production frontend origin.
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000

# Shared secret required for the frontend's server-side calls
# (POST /api/rooms, GET /internal/rooms/:code/access-token).
# Must match SOCKET_PROVIDER_SECRET on the frontend.
SOCKET_PROVIDER_SECRET=replace_with_a_long_random_string
