# Spotify OAuth for the Next.js app.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# Must be at least 32 characters. Use a strong random value in production.
SESSION_PASSWORD=replace_with_at_least_32_random_characters

# Browser-facing socket URL. In production, use the deployed socket provider origin.
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:4001

# Server-to-server socket provider URL used by Next.js API routes.
SOCKET_PROVIDER_URL=http://127.0.0.1:4001
